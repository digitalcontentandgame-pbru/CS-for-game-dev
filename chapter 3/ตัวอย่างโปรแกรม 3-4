using UnityEngine;
using System; // สำหรับ Random

public class NumberGuessingGame : MonoBehaviour
{
    private int secretNumber;
    private int maxGuesses = 5;
    private int guessesRemaining;
    public int guessNumber = 0;

    void Start()
    {
        // ใช้ตัวดำเนินการทางคณิตศาสตร์: การกำหนดค่า
        // สุ่มตัวเลขระหว่าง 1 ถึง 100
        secretNumber = UnityEngine.Random.Range(1, 101); 
        guessesRemaining = maxGuesses;
        
        Debug.Log(
"The number guessing game has begun! Guess the number between 1 and 100."
         );
    }

    // เมท็อดนี้ถูกเรียกเมื่อผู้เล่นทายตัวเลข
    public void CheckGuess(int guess)
    {
        // ใช้ตัวดำเนินการทางคณิตศาสตร์: การลบ
        guessesRemaining--;

        // ตรวจสอบเงื่อนไขการทายตัวเลขด้วยตัวดำเนินการเปรียบเทียบ
        if (guess == secretNumber)
        {
            // ใช้ตัวดำเนินการเปรียบเทียบ: == (เท่ากัน)
            Debug.Log(
             $"Excellent! You guessed correctly: {secretNumber}"
            );
            // หยุดเกม
            return;
        }
        
        // ใช้ตัวดำเนินการตรรกะ: || (หรือ)
        if (guess < 1 || guess > 100)
        {
// ปรับจำนวนทายที่ลดลงเมื่อเข้าสู่เมท็อดกลับคืนมา เพราะทายผิดพลาดนอกขอบเขต
            guessesRemaining++; 
            Debug.LogWarning(
"Please guess only numbers within the range of 1 to 100!"
            );
            return;
        }

        // ใช้ตัวดำเนินการเปรียบเทียบ: > และ <
        if (guess > secretNumber)
        {
            Debug.Log("The number you guessed was [too many]");
        }
        else // (guess < secretNumber)
        {
            Debug.Log("The number you guessed was [too small]");
        }




        // ใช้ตัวดำเนินการตรรกะ: && (และ) และ ! (ไม่)
        // ตรวจสอบเงื่อนไขจบเกม
        bool isGameOver = (guessesRemaining <= 0) && 
                          (guess != secretNumber);


        if (isGameOver)
        {
            // ใช้ตัวดำเนินการเปรียบเทียบ: <=
            Debug.Log(
              "No chance! The secret number is: {secretNumber}"
            );
        }
        else
        {
            // ใช้ตัวดำเนินการตรรกะ: !
            Debug.Log($"Guess Remaining: {guessesRemaining}");
        }
    }
    
    void Update()
    {
        // ถ้าไม่กด Space จะไม่ตรวจสอบค่าที่เดา
        if (!Keyboard.current.Space.isPressed)
        {
            return;
        }

        // ถ้ากด Space จะนำค่าจาก inspector มาตรวจ
        CheckGuess(guessNumber);
    }
}
