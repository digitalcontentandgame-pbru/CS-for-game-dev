using System.Collections.Generic;

public static class ItemDatabase
{

    private static Dictionary<int, Item> items = 
                                new Dictionary<int, Item>();

    static ItemDatabase()
    {
        // สร้างข้อมูลไอเทมตัวอย่าง
        items[1] = new Item(
                1, "Iron Sword", ItemType.Weapon, maxStack: 1);
        items[2] = new Item(
                2, "Health Potion", ItemType.Potion, maxStack: 10);
        items[3] = new Item(
                3, "Leather Armor", ItemType.Armor, maxStack: 1);
        items[4] = new Item(
                4, "Herb", ItemType.Material, maxStack: 20);
    }

    public static Item GetItemById(int id)
    {
        if (items.TryGetValue(id, out Item item))
        {
            return item;
        }

        return null;
    }
}
