public enum ItemType
{
    Weapon,
    Armor,
    Potion,
    Material,
    Misc
}

public class Item
{
    public int Id { get; private set; }
    public string Name { get; private set; }
    public ItemType Type { get; private set; }
    public int MaxStack { get; private set; } // จำนวนซ้อนสูงสุด

    public Item(int id, string name, ItemType type, int maxStack)
    {
        Id = id;
        Name = name;
        Type = type;
        MaxStack = maxStack;
    }
}
