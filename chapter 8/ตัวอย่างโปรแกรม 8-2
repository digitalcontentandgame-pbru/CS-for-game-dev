using UnityEngine;

public class WeaponController : MonoBehaviour
{
    public GameObject projectilePrefab;
    public float baseSpeed = 20f;

    public void FireProjectile()
    {
        GameObject projectileGO = Instantiate(projectilePrefab, transform.position, transform.rotation);
        
// รับสคริปต์ Projectile และกำหนดความเร็ว 
// แต่ให้ Projectile.Start() จัดการการเคลื่อนที่
        Projectile projScript = 
                         projectileGO.GetComponent<Projectile>();
        if (projScript != null)
        {
            projScript.speed = baseSpeed; // กำหนดค่าในตัวแปร
        }
    }
}
